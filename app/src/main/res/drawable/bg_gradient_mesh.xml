<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base deep black background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#050505" />
        </shape>
    </item>
    
    <!-- Top-left glowing red gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="450dp"
                android:centerX="0.0"
                android:centerY="0.0"
                android:startColor="#1AFF1744"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Bottom-right glowing purple gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="450dp"
                android:centerX="1.0"
                android:centerY="1.0"
                android:startColor="#1AD500F9"
                android:endColor="#00000000" />
        </shape>
    </item>
</layer-list>
