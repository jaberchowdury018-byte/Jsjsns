<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_mesh"
    tools:context=".ui.main.MainActivity">

    <!-- Top Bar: System Console HUD -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Left Column: Status Indicators -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Red blinking online status indicator -->
                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/bg_prime_badge"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SYSTEM ONLINE"
                    android:textColor="#FF1744"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <ImageView
                    android:id="@+id/batteryIcon"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_battery"
                    android:contentDescription="Battery Status"
                    android:tint="#66FFFFFF" />

                <TextView
                    android:id="@+id/batteryText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="#66FFFFFF"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Center Column: App Brand Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_centerInParent="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MYRA"
                android:textColor="#FF1744"
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI COMPANION v1.0"
                android:textColor="#66FFFFFF"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:layout_marginTop="1dp" />
        </LinearLayout>

        <!-- Right Column: Settings Action Button -->
        <ImageButton
            android:id="@+id/settingsBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_settings"
            android:background="@drawable/bg_settings_btn"
            android:padding="8dp"
            android:scaleType="fitCenter"
            android:tint="#EEEEEE"
            android:contentDescription="Settings" />
    </RelativeLayout>

    <!-- Translucent Terminal / Chat Container -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_transcript_box"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/orbContainer" />

    <!-- Visual Interactive Orb Area -->
    <FrameLayout
        android:id="@+id/orbContainer"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/waveformView">

        <com.example.ui.main.OrbAnimationView
            android:id="@+id/orbAnimationView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <!-- Dynamic Audio Waveform -->
    <com.example.ui.main.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="match_parent"
        android:layout_height="45dp"
        android:layout_marginHorizontal="32dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toTopOf="@id/bottomInputLayout" />

    <!-- Bottom Controls Deck -->
    <LinearLayout
        android:id="@+id/bottomInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingBottom="36dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Command Input Field Container -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <EditText
                android:id="@+id/manualInput"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Type a command or chat..."
                android:textColor="#EEEEEE"
                android:textColorHint="#555555"
                android:inputType="textShortMessage"
                android:textSize="14sp" />

            <ImageButton
                android:id="@+id/sendBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_send"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="#FF1744"
                android:contentDescription="Send text" />
        </LinearLayout>

        <!-- Primary Accent Mic Toggle Action -->
        <ImageButton
            android:id="@+id/micToggleBtn"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/bg_mic_button"
            android:src="@drawable/ic_mic_on"
            android:tint="#FFFFFF"
            android:elevation="4dp"
            android:scaleType="centerInside"
            android:contentDescription="Toggle Mic" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
